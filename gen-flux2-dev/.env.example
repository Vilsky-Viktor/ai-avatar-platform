# GCP
PROJECT_ID=
BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=/workspace/gcp-json-key.json

# Pub/Sub
SUBSCRIPTION_ID=
RESULT_TOPIC_ID=
JOB_TOPIC_ID=

# Firestore
DB_NAME=ai-avatar-db
JOBS_COLLECTION_NAME=jobs

# Models
MODEL_NAME=flux.2-dev
FLUX2_MODEL_PATH=/workspace/models/flux.2-dev
HF_HOME=/workspace/models
TORCHINDUCTOR_CACHE_DIR=/workspace/models/torch_compile_cache

# Face similarity
INSIGHTFACE_MODEL=buffalo_l
ADAFACE_MODEL_DIR=/workspace/models/adaface
ADAFACE_ARCHITECTURE=ir_101
EMBEDDING_CACHE_TTL=3600
EMBEDDING_CACHE_MAX_SIZE=500
MIN_FACE_MATCH=0.4

# Media cache
MEDIA_CACHE_TTL_SECONDS=3600
TMP_TTL_SECONDS=604800

# RunPod
RUNPOD_POD_ID=
INACTIVITY_TIMEOUT=300

# Precision and inference
MODEL_PRECISION=bf16
MODEL_SAMPLER_NAME=dpm++
WARMUP_STEPS=35
USE_MODEL_COMPILATION=true

# Logging
LOG_LEVEL=INFO
