PROJECT_ID=loom24-mvp
BUCKET_NAME=loom24-mvp.firebasestorage.app
GOOGLE_APPLICATION_CREDENTIALS=/root/.config/gcloud/gcp-json-key.json
JOB_MANAGER_URL=http://job-manager:3000

SUBSCRIPTION_ID=face-matcher-sub
WORKFLOW_MANAGER_TOPIC=workflow-manager

# Number of face recognition instances loaded into the pool.
# Each instance holds the full AdaFace + InsightFace model in memory.
# Set POOL_SIZE=MAX_CONCURRENT_MESSAGES to avoid blocking.
POOL_SIZE=1
MAX_CONCURRENT_MESSAGES=1

# InsightFace
INSIGHTFACE_MODEL=buffalo_l
INSIGHTFACE_ROOT=/models/insightface

# AdaFace — mount a volume containing the *.ckpt checkpoint file
ADAFACE_MODEL_DIR=/app/models/adaface
ADAFACE_ARCHITECTURE=ir_101

EMBEDDING_CACHE_TTL=3600
EMBEDDING_CACHE_MAX_SIZE=500
