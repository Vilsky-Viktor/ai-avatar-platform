rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /media/{userFolder}/{allPaths=**} {
      allow read, write: if request.auth != null && userFolder == request.auth.uid + "-user";
    }

    match /voices/{allPaths=**} {
      allow read: if request.auth != null;
    }
  }
}
